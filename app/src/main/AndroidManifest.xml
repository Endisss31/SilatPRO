<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.camera.any" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_logo_silatpro"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logo_silatpro_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SilatPRO"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".ActivityOpenSplash"
            android:exported="true"
            android:theme="@style/Theme.SilatPRO.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ActivitySplash"
            android:exported="false"
            android:theme="@style/Theme.SilatPRO.Splash" />

        <activity
            android:name=".ActivityMain"
            android:exported="false" />

        <activity
            android:name=".ActivityTentang"
            android:exported="false" />

        <activity
            android:name=".ActivityDetailGerakan"
            android:exported="false" />

        <activity
            android:name=".ActivityKameraEvaluasi"
            android:exported="false"
            android:theme="@style/Theme.SilatPRO.Kamera" />

        <activity
            android:name=".ActivityKlasifikasiGerakan"
            android:exported="false"
            android:theme="@style/Theme.SilatPRO.Kamera" />


        <activity
            android:name=".ActivityHasilEvaluasi"
            android:exported="false" />

    </application>

</manifest>
