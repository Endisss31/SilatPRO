<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/putih_pudar"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/biru_utama"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:navigationIcon="@drawable/ic_panah_kiri"
        app:navigationIconTint="@color/putih"
        app:titleCentered="false"
        app:titleTextAppearance="@style/TextAppearance.Toolbar.Title"
        app:titleTextColor="@color/putih" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <!-- Layer 1: Hero Image -->
                <ImageView
                    android:id="@+id/imgHeader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/detail_posisi"
                    android:scaleType="centerCrop" />

                <!-- Layer 2: Dark gradient overlay (bottom 60%) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_overlay_gelap" />


                <!-- Layer 5: Kategori Badge (top-right) -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:layout_marginTop="72dp"
                    android:background="@drawable/bg_badge_putih"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="7dp">

                    <TextView
                        android:id="@+id/txtKategoriDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/biru_gelap"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Layer 6: Bottom info block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="22dp">


                    <TextView
                        android:id="@+id/txtNamaGerakan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/putih"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtHeroDeskripsi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="2"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- ─── Target Badge ─── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_badge_merah"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtTargetGerakan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:textColor="@color/biru_gelap"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>

                <!-- ─── Seksi: Definisi Gerakan ─── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_kartu"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_accent_bar" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppins"
                            android:text="@string/detail_definisi_gerakan"
                            android:textColor="@color/abu_gelap"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Deskripsi Card dengan left accent -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">


                    <TextView
                        android:id="@+id/txtDeskripsi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_kartu"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="6dp"
                        android:padding="18dp"
                        android:paddingStart="22dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                </FrameLayout>

                <!-- Langkah Card -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <!-- Accent bar kiri (warna berbeda) -->

                    <TextView
                        android:id="@+id/txtLangkahGerakan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_biru"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="5dp"
                        android:padding="18dp"
                        android:paddingStart="22dp"
                        android:textColor="@color/biru_terang"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </FrameLayout>



            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/putih"
        android:elevation="8dp">

        <!-- Top divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A000000" />

        <!-- CTA Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabMulaiLatihan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="18dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/biru_utama"
            android:elevation="4dp"
            android:fontFamily="@font/poppins"
            android:text="@string/btn_mulai_evaluasi"
            android:textColor="@color/putih"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_kamera"
            app:iconTint="@color/putih" />
    </FrameLayout>
</LinearLayout>

