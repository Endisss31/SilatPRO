<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/utama"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- ViewPager2 untuk slide antar Fragment -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerUtama"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never" />

    <!-- Bottom Navigation Bar — 4 tab + FAB kamera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="15dp"
        android:background="@drawable/bg_nav_bawah"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:gravity="center_vertical"
            android:elevation="12dp"
            android:background="@drawable/bg_nav_bawah"
            android:orientation="horizontal">

            <!-- Tab Beranda -->
            <LinearLayout
                android:id="@+id/tabBeranda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgTabBeranda"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/nav_beranda"
                    android:src="@drawable/ic_beranda"
                    app:tint="@color/biru_utama" />

                <TextView
                    android:id="@+id/txtTabBeranda"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins"
                    android:text="@string/nav_beranda"
                    android:textColor="@color/biru_utama"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Tab Galeri -->
            <LinearLayout
                android:id="@+id/tabGaleri"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgTabGaleri"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Galeri"
                    android:src="@drawable/ic_galeri"
                    app:tint="@color/abu_terang" />

                <TextView
                    android:id="@+id/txtTabGaleri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins"
                    android:text="Galeri"
                    android:textColor="@color/abu_terang"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- FAB Kamera (tengah) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabKamera"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:contentDescription="@string/nav_kamera"
                    android:src="@drawable/ic_kamera"
                    app:backgroundTint="@color/biru_utama"
                    app:borderWidth="0dp"
                    app:elevation="8dp"
                    app:fabCustomSize="52dp"
                    app:maxImageSize="24dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance_SilatPRO_FabCircle"
                    app:tint="@color/putih" />
            </LinearLayout>

            <!-- Tab Riwayat -->
            <LinearLayout
                android:id="@+id/tabRiwayat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgTabRiwayat"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/nav_riwayat"
                    android:src="@drawable/ic_riwayat"
                    app:tint="@color/abu_terang" />

                <TextView
                    android:id="@+id/txtTabRiwayat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins"
                    android:text="@string/nav_riwayat"
                    android:textColor="@color/abu_terang"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Tab Tentang -->
            <LinearLayout
                android:id="@+id/tabTentang"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgTabTentang"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Tentang"
                    android:src="@drawable/ic_tentang"
                    app:tint="@color/abu_terang" />

                <TextView
                    android:id="@+id/txtTabTentang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins"
                    android:text="Tentang"
                    android:textColor="@color/abu_terang"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
