<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/utama"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_premium"
    android:orientation="vertical">

    <!-- ViewPager Konten Onboarding -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/pagerOnboarding"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Area Bawah: Indikator + Tombol -->
    <LinearLayout
        android:id="@+id/layoutAreaBawah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="8dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <!-- Dot Indicator -->
        <LinearLayout
            android:id="@+id/layoutIndikator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal" />

        <!-- Baris Tombol -->
        <LinearLayout
            android:id="@+id/layoutBawah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Tombol Lewati -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLewati"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins"
                android:text="@string/btn_lewati"
                android:textColor="#BBFFFFFF"
                android:textSize="15sp" />

            <!-- Tombol Selanjutnya / Mulai -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelanjutnya"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.3"
                android:backgroundTint="@color/putih"
                android:elevation="6dp"
                android:fontFamily="@font/poppins"
                android:text="@string/btn_selanjutnya"
                android:textColor="@color/biru_utama"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_panah_kanan"
                app:iconGravity="end"
                app:iconTint="@color/biru_utama" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
