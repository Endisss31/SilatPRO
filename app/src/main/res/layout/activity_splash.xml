<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_premium"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Lingkaran glow di belakang logo -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo container dengan efek shadow -->
        <LinearLayout
            android:id="@+id/containerLogo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgLogoSplash"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_badge_putih"
                android:src="@drawable/logosilatpro" />
        </LinearLayout>

        <!-- Nama aplikasi -->
        <TextView
            android:id="@+id/txtNamaAplikasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/poppins"
            android:letterSpacing="0.08"
            android:text="@string/app_name"
            android:textColor="@color/putih"
            android:textSize="38sp"
            android:textStyle="bold" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/txtTaglineSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:text="@string/splash_tagline"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp" />

        <!-- Divider dekoratif -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_divider_putih" />
    </LinearLayout>

    <!-- Loading indicator di bawah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progressSplash"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/putih"
            android:progressTint="@color/putih" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins"
            android:text="Memuat..."
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
